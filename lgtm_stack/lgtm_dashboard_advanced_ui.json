{
  "title": "Application Observability: Golden Signals",
  "uid": "lgtm-python-dash-v2",
  "tags": [
    "python",
    "as-code",
    "lgtm",
    "production"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Critical Errors (Last 1h)",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({container=~\".*chaos-app.*|.*weather-service.*\"} | json | level=\"error\" [1h]))",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "sparkline",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      }
    },
    {
      "type": "gauge",
      "title": "HTTP Success Rate",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "id": 2,
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "(sum(count_over_time({container=~\".*chaos-app.*|.*weather-service.*\"} | json | status_code >= 200 and status_code < 400 [$__auto])) / sum(count_over_time({container=~\".*chaos-app.*|.*weather-service.*\"} | json | status_code > 0 [$__auto]))) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "green",
                "value": 98
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({container=~\".*chaos-app.*|.*weather-service.*\"} | json | status_code > 0 [$__auto]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Application Log Volume & Severity",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 4,
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (level) (count_over_time({container=~\".*chaos-app.*|.*weather-service.*\"} | json [$__auto]))",
          "refId": "A",
          "legendFormat": "{{level}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 25,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "type": "logs",
      "title": "Live Container Logs",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 5,
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{container=~\".*chaos-app.*|.*weather-service.*\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true
      }
    },
    {
      "type": "table",
      "title": "Slow Traces (>100ms)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 6,
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ .service.name = \"chaos-service\" || .service.name = \"weather-service\" } | duration > 100ms",
          "refId": "A"
        }
      ],
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Start time",
            "desc": true
          }
        ]
      }
    }
  ]
}