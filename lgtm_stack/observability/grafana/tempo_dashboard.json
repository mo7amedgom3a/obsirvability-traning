        "y": 26
      },
      "id": 10,
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ .service.name = \"weather-service\" } | duration > 50ms",
          "refId": "A"
        }
